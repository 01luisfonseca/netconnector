# Netconnector Server Configuration (VPS)

# Port for gRPC communication with local agents
GRPC_PORT=50051

# Port for public HTTP traffic (Reverse Proxy)
HTTP_PORT=8080

# Path to the SQLite database file for domain mappings
DB_PATH=./mappings.db

# Optional: Path to TLS certificate and key for secure gRPC
# If these files exist in certs/, they will be loaded automatically.
# TLS_CERT_FILE=certs/server.crt
# TLS_KEY_FILE=certs/server.key
